generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Employee {
  id         String   @id @default(uuid())
  name       String
  pinHash    String   @map("pin_hash")
  email      String?
  phone      String?
  role       String   @default("field")
  hourlyRate Float?   @map("hourly_rate")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  managedJobs  Job[]        @relation("JobPM")
  timeEntries  TimeEntry[]
  submissions  Submission[] @relation("SubmissionEmployee")
  approvedSubs Submission[] @relation("SubmissionApprover")

  @@map("employees")
}

model Job {
  id               String   @id @default(uuid())
  foundationJobId  String   @unique @map("foundation_job_id")
  name             String
  shortName        String?  @map("short_name")
  status           String   @default("active")
  isPrevailingWage Boolean  @default(false) @map("is_prevailing_wage")
  state            String?
  address          String?
  pmId             String?  @map("pm_id")
  pm               Employee? @relation("JobPM", fields: [pmId], references: [id])
  createdAt        DateTime @default(now()) @map("created_at")
  syncedAt         DateTime? @map("synced_at")

  costCodes   JobCostCode[]
  timeEntries TimeEntry[]

  @@map("jobs")
}

model CostCode {
  id              String  @id @default(uuid())
  code            String  @unique
  description     String
  category        String  @default("hvac")
  acceptsLabor    Boolean @default(true) @map("accepts_labor")
  acceptsMaterial Boolean @default(false) @map("accepts_material")
  acceptsSub      Boolean @default(false) @map("accepts_sub")
  isActive        Boolean @default(true) @map("is_active")

  jobCostCodes JobCostCode[]
  timeEntries  TimeEntry[]

  @@map("cost_codes")
}

model JobCostCode {
  id               String    @id @default(uuid())
  jobId            String    @map("job_id")
  job              Job       @relation(fields: [jobId], references: [id])
  costCodeId       String    @map("cost_code_id")
  costCode         CostCode  @relation(fields: [costCodeId], references: [id])
  budgetedLabor    Float?    @map("budgeted_labor")
  budgetedMaterial Float?    @map("budgeted_material")
  budgetedSub      Float?    @map("budgeted_sub")
  budgetedHours    Float?    @map("budgeted_hours")
  syncedAt         DateTime? @map("synced_at")

  @@unique([jobId, costCodeId])
  @@map("job_cost_codes")
}

model TimeEntry {
  id           String    @id @default(uuid())
  employeeId   String    @map("employee_id")
  employee     Employee  @relation(fields: [employeeId], references: [id])
  workDate     DateTime  @map("work_date")
  jobId        String    @map("job_id")
  job          Job       @relation(fields: [jobId], references: [id])
  costCodeId   String    @map("cost_code_id")
  costCode     CostCode  @relation(fields: [costCodeId], references: [id])
  hours        Float
  description  String
  quantity     Float?
  unit         String?
  crewMembers  String    @default("[]") @map("crew_members")
  notes        String?
  aiConfidence Float?    @map("ai_confidence")
  isFlagged    Boolean   @default(false) @map("is_flagged")
  flagReason   String?   @map("flag_reason")
  status       String    @default("draft")
  submissionId String?   @map("submission_id")
  submission   Submission? @relation(fields: [submissionId], references: [id])
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("time_entries")
}

model Submission {
  id            String    @id @default(uuid())
  employeeId    String    @map("employee_id")
  employee      Employee  @relation("SubmissionEmployee", fields: [employeeId], references: [id])
  workDate      DateTime  @map("work_date")
  audioUrl      String?   @map("audio_url")
  transcript    String?
  aiRawResponse String?   @map("ai_raw_response")
  totalHours    Float?    @map("total_hours")
  status        String    @default("processing")
  submittedAt   DateTime? @map("submitted_at")
  approvedAt    DateTime? @map("approved_at")
  approvedBy    String?   @map("approved_by")
  approver      Employee? @relation("SubmissionApprover", fields: [approvedBy], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")

  timeEntries TimeEntry[]

  @@map("submissions")
}
